# ---------------------------------------------------------------------------
# Banco de dados (Supabase Postgres)
#
# No painel do Supabase: Project Settings > Database > Connection string.
# Copie os dois formatos abaixo (troque [PROJECT-REF] e [PASSWORD] pelos seus):
#
# DATABASE_URL = "Connection pooling" (porta 6543, modo transaction/pgbouncer)
#   → usada pela aplicação em runtime (várias conexões curtas/serverless-friendly)
# DIRECT_URL   = "Connection string" direta (porta 5432)
#   → usada só por `prisma migrate` / `prisma db push`, que não funcionam
#     através do pgbouncer em modo transaction
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# ---------------------------------------------------------------------------
# NextAuth
# ---------------------------------------------------------------------------
# URL pública onde a aplicação roda (sem barra no final)
NEXTAUTH_URL="http://localhost:3000"
# Gere um valor aleatório forte, ex: `openssl rand -base64 32`
NEXTAUTH_SECRET="troque-por-um-valor-aleatorio-forte"

# URL pública usada para montar o link de indicação (/cliente/registro?ref=...).
# Se omitido, usa a origem da própria requisição.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# WhatsApp (Evolution API ou Z-API) — opcional
# Deixe em branco para rodar sem notificações (o sistema funciona normalmente,
# só não envia mensagens; tudo fica logado no console do servidor).
# ---------------------------------------------------------------------------
WHATSAPP_PROVIDER="" # "evolution" ou "zapi"
WHATSAPP_API_URL=""
WHATSAPP_API_KEY=""
WHATSAPP_INSTANCE="" # apenas para Evolution API

# ---------------------------------------------------------------------------
# Cron de expiração de pontos (opcional)
# Usado por um agendador externo (Vercel Cron, GitHub Actions, cron do SO)
# para chamar POST /api/cron/expirar-pontos com o header x-cron-secret.
# ---------------------------------------------------------------------------
CRON_SECRET="troque-por-um-valor-aleatorio"
